---
import ThemeBlackFooter from "starlight-theme-black/overrides/Footer.astro"
---

<footer class="fart-section">
  <hr class="fart-hr" />
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <p class="attribution">
          <a href="https://github.com/FartLabs/pixel-planet" class="fart-link"
            >Pixel Planet</a
          > by <a href="https://github.com/FartLabs" class="fart-link"
            >FartLabs</a
          > for use with <a href="https://ui.shadcn.com" class="fart-link"
            >Shadcn</a
          >.
        </p>
        <p class="attribution" style="margin-top: 0.5rem;">
          Based on <a
            href="https://github.com/Timur310/PixelPlanets"
            class="fart-link">PixelPlanets</a
          > by <a href="https://github.com/Timur310" class="fart-link"
            >@Timur310</a
          >.
        </p>
      </div>

      <div class="footer-nav">
        <div class="nav-group">
          <h5>Resources</h5>
          <div class="nav-links">
            <a href="/getting-started/introduction">Docs</a>
            <a href="/components">Components</a>
            <a href="https://github.com/FartLabs/pixel-planet">GitHub</a>
            <a href="https://css.fart.tools">Fart.css</a>
          </div>
        </div>

        <div class="nav-group">
          <h5>Community</h5>
          <div class="nav-links">
            <a href="https://fartlabs.org">FartLabs</a>
            <a href="https://github.com/FartLabs">GitHub</a>
            <a href="https://go.fart.tools/chat">Discord</a>
            <a href="https://x.com/intent/follow?screen_name=fartlabs_org">X</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<ThemeBlackFooter {...Astro.props} />

<style>
  footer {
    padding: 2rem 0 1.5rem;
    margin-top: 2rem;
  }

  .footer-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .footer-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-brand {
    max-width: 300px;
  }

  .brand-text {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--fart-primary);
    margin-bottom: 0.25rem;
  }

  .attribution {
    font-size: 0.85rem;
    color: var(--fart-off-white);
    opacity: 0.8;
  }

  .footer-nav {
    display: flex;
    gap: 3rem;
  }

  .nav-group h5 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--fart-primary);
    margin-bottom: 0.75rem;
    opacity: 0.9;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-links a {
    font-size: 0.9rem;
    color: var(--fart-off-white);
    text-decoration: none;
    transition:
      color 0.2s,
      transform 0.2s;
    width: fit-content;
  }

  .nav-links a:hover {
    color: var(--fart-primary);
    transform: translateX(2px);
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
    padding-top: 1rem;
    border-top: 1px solid rgba(var(--fart-highlight-rgb, 128, 128, 128), 0.1);
    font-size: 0.8rem;
    color: var(--fart-off-white);
    opacity: 0.6;
  }

  @media (max-width: 640px) {
    .footer-main {
      flex-direction: column;
      gap: 2rem;
    }

    .footer-nav {
      width: 100%;
      justify-content: space-between;
      gap: 1rem;
    }
  }
</style>
