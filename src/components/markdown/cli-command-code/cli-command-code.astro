---
import { CliCommandCodeInternal } from "./_cli-command-code-internal"

type Action = "install" | "run"
const packageManagers = ["pnpm", "npm", "yarn", "bun", "deno"] as const
type PackageManager = (typeof packageManagers)[number]

const ACTION_PACKAGE_MANAGER_MAP: Record<
  Action,
  Record<PackageManager, string>
> = {
  install: {
    npm: `npm install`,
    pnpm: `pnpm add`,
    yarn: `yarn add`,
    bun: `bun add`,
    deno: `deno add`,
  },
  run: {
    npm: `npx`,
    pnpm: `pnpm dlx`,
    yarn: `yarn`,
    bun: `bunx --bun`,
    deno: `deno x`,
  },
}

type Props = {
  command: string
  action: Action
}

const { command, action } = Astro.props
const commands = packageManagers.map(packageManager => {
  let finalCommand = command
  if (packageManager === "deno") {
    if (action === "run") {
      // For 'run', prefix the first part of the command (the package name) with 'npm:'
      const parts = command.split(" ")
      parts[0] = `npm:${parts[0]}`
      finalCommand = parts.join(" ")
    } else if (action === "install") {
      // For 'install', prefix each package name with 'npm:'
      finalCommand = command
        .split(" ")
        .map(pkg => (pkg.startsWith("npm:") ? pkg : `npm:${pkg}`))
        .join(" ")
    }
  }

  return {
    label: packageManager,
    code: `${ACTION_PACKAGE_MANAGER_MAP[action][packageManager]} ${finalCommand}`,
  }
})
---

<div>
  <CliCommandCodeInternal client:load commands={commands} />
</div>
